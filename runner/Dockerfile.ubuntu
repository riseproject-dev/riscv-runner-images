    echo "${PYTHON311_SHA256}  Python-${PYTHON311_VERSION}.tgz" | sha256sum --check

    # Unpack, Configure, Build, Install
    tar -xzf Python-${PYTHON311_VERSION}.tgz
    pushd Python-${PYTHON311_VERSION}
    ./configure --prefix=/opt/python-3.11 --with-ensurepip=install --disable-test-modules
    make -j$(nproc)

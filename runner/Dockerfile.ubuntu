# Download Node.js 20
FROM base-builder AS node-20

ARG NODE20_VERSION=20.20.2
ARG NODE20_SHA256=97a1b381eb457a904973cd3fa7999feb4fded5d286f4da08bbd0bf112601b0f4 # https://unofficial-builds.nodejs.org/download/release/v20.20.2/SHASUMS256.txt
RUN bash -eux -o pipefail <<'EOF'
    # Download Node.js 20
    curl -fsSL --retry 25 --retry-all-errors "https://unofficial-builds.nodejs.org/download/release/v${NODE20_VERSION}/node-v${NODE20_VERSION}-linux-riscv64.tar.xz" \
        -o "node-v${NODE20_VERSION}-linux-riscv64.tar.xz"

    # Verify package integrity
    echo "${NODE20_SHA256}  node-v${NODE20_VERSION}-linux-riscv64.tar.xz" | sha256sum --check

    # Unpack to ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION}/riscv64
    mkdir -p ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION}/riscv64
    tar -xJf "node-v${NODE20_VERSION}-linux-riscv64.tar.xz" -C ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION}/riscv64 --strip-components 1
    touch ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION}/riscv64.complete
    rm "node-v${NODE20_VERSION}-linux-riscv64.tar.xz"

    # Smoke test
    ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION}/riscv64/bin/node --version
EOF


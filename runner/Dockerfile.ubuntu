
# Build Python build image, to be used to build various Python versions

ARG UBUNTU_VERSION=latest
FROM docker.io/ubuntu:${UBUNTU_VERSION} AS python-builder

ENV DEBIAN_FRONTEND=noninteractive

RUN bash -eux -o pipefail <<EOF
    apt-get update -qq
    apt-get install -qq -y --no-install-recommends \
        build-essential \
        ca-certificates \
        gcc \
        g++ \
        libbz2-dev \
        libexpat1-dev \
        libffi-dev \
        libgdbm-dev \
        liblzma-dev \
        libncursesw5-dev \
        libreadline-dev \
        libsqlite3-dev \
        libssl-dev \
        make \
        pkg-config \
        tk-dev \
        uuid-dev \
        wget \
        zlib1g-dev \
     && true

  rm -rf /var/lib/apt/lists/*
EOF

# Build Python 3.10
FROM python-builder AS python-3.10

ARG PYTHON310_VERSION=3.10.20
ARG PYTHON310_SHA256=4ff5fd4c5bab803b935019f3e31d7219cebd6f870d00389cea53b88bbe935d1a # https://www.python.org/downloads/release/python-31020
RUN bash -eux -o pipefail <<EOF
    # Download Python 3.10 source tarball
    wget --progress=dot:giga https://www.python.org/ftp/python/${PYTHON310_VERSION}/Python-${PYTHON310_VERSION}.tgz

    # Verify package integrity
    echo "${PYTHON310_SHA256}  Python-${PYTHON310_VERSION}.tgz" | sha256sum --check

    # Unpack, Configure, Build, Install
    tar -xzf Python-${PYTHON310_VERSION}.tgz
    pushd Python-${PYTHON310_VERSION}
    ./configure --prefix=/opt/python-3.10 --with-ensurepip=install --disable-test-modules
    make -j$(nproc)
    make altinstall
    popd
    rm -rf Python-${PYTHON310_VERSION}
EOF


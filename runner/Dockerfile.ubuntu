
# Base builder image with common download and build tools

ARG OS_VERSION
FROM docker.io/ubuntu:${OS_VERSION} AS base-builder

ENV RUNNER_TOOL_CACHE=/opt/hostedtoolcache

ENV DEBIAN_FRONTEND=noninteractive

RUN bash -eux -o pipefail <<'EOF'
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        cmake \
        g++ \
        gcc \
        git \
        libssl-dev \
        make \
        pkg-config \
        unzip \
        wget \
        xz-utils \
     && true

  rm -rf /var/lib/apt/lists/*
EOF

ARG OS_VERSION

# Build Python 3.10
FROM base-builder AS python-3.10

ARG PYTHON310_VERSION=3.10.20
ARG PYTHON310_TAG=${PYTHON310_VERSION}-24017034265
ARG PYTHON310_SHA256=7ce4c81b47a41b8a481489b7b09c6b506167250d38de1cb7770d29312cc4dab0 # https://github.com/riseproject-dev/python-versions/releases/${PYTHON310_TAG}
RUN bash -eux -o pipefail <<'EOF'
    # Download Python 3.10
    curl -fsSL --retry 25 --retry-all-errors https://github.com/riseproject-dev/python-versions/releases/download/${PYTHON310_TAG}/python-${PYTHON310_VERSION}-linux-${OS_VERSION}-riscv64.tar.gz \
        -o python-${PYTHON310_VERSION}-linux-${OS_VERSION}-riscv64.tar.gz

    # Verify package integrity
    echo "${PYTHON310_SHA256}  python-${PYTHON310_VERSION}-linux-${OS_VERSION}-riscv64.tar.gz" | sha256sum --check

    # Unpack tar file
    mkdir -p ${RUNNER_TOOL_CACHE}/Python/${PYTHON310_VERSION}/riscv64
    tar -xzf python-${PYTHON310_VERSION}-linux-${OS_VERSION}-riscv64.tar.gz -C ${RUNNER_TOOL_CACHE}/Python/${PYTHON310_VERSION}/riscv64
    touch ${RUNNER_TOOL_CACHE}/Python/${PYTHON310_VERSION}/riscv64.complete
    rm -f python-${PYTHON310_VERSION}-linux-${OS_VERSION}-riscv64.tar.gz

    # Smoke test
    ${RUNNER_TOOL_CACHE}/Python/${PYTHON310_VERSION}/riscv64/bin/python3.10 --version
EOF


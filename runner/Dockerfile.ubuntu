# Download Gradle
FROM base-builder AS gradle

ARG GRADLE_VERSION=9.4.1
ARG GRADLE_SHA256=2ab2958f2a1e51120c326cad6f385153bb11ee93b3c216c5fccebfdfbb7ec6cb # https://services.gradle.org/distributions/gradle-9.4.1-bin.zip.sha256
RUN bash -eux -o pipefail <<'EOF'
    # Download Gradle
    curl -fsSL --retry 25 --retry-all-errors https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip \
        -o gradle-${GRADLE_VERSION}-bin.zip

    # Verify package integrity
    echo "${GRADLE_SHA256}  gradle-${GRADLE_VERSION}-bin.zip" | sha256sum --check

    # Unpack to /usr/share
    unzip -q gradle-${GRADLE_VERSION}-bin.zip -d /usr/share
    rm gradle-${GRADLE_VERSION}-bin.zip
EOF

# Download Apache Maven
FROM base-builder AS maven

ARG MAVEN_VERSION=3.9.14
ARG MAVEN_SHA512=d50af8ab5e6005b46a07f0ce9d3719e67cfdf898da988a84871304cd59fb1af0fef2f99dea709e6e66f21f732f905979b5c2dce6b6860406f60a70e84d9cf0b8 # https://archive.apache.org/dist/maven/maven-3/3.9.14/binaries/apache-maven-3.9.14-bin.tar.gz.sha512
RUN bash -eux -o pipefail <<'EOF'
    # Download Apache Maven
    curl -fsSL --retry 25 --retry-all-errors https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz \
        -o apache-maven-${MAVEN_VERSION}-bin.tar.gz

    # Verify package integrity
    echo "${MAVEN_SHA512}  apache-maven-${MAVEN_VERSION}-bin.tar.gz" | sha512sum --check

    # Unpack to /usr/share
    tar -xzf apache-maven-${MAVEN_VERSION}-bin.tar.gz -C /usr/share
    rm apache-maven-${MAVEN_VERSION}-bin.tar.gz
EOF

# Download Rust 1.94.0
FROM base-builder AS rust

ARG RUSTUP_VERSION=1.29.0
ARG RUSTTOOLCHAIN_VERSION=1.94.1
ENV RUSTUP_HOME=/build/rust/rustup
ENV CARGO_HOME=/build/rust/cargo
RUN bash -eux -o pipefail <<'EOF'
    curl -fsSL --retry 25 --retry-all-errors https://sh.rustup.rs | sh -s -- \
        -y \
        --default-toolchain ${RUSTTOOLCHAIN_VERSION} \
        --profile minimal \
        --component rustc,rust-std,cargo,rustfmt,clippy
EOF

ENV PATH=${RUSTUP_HOME}/bin:${CARGO_HOME}/bin:${PATH}

# Dockerload docker-compose
FROM base-builder AS docker-compose

ARG DOCKERCOMPOSE_VERSION=2.38.2
ARG DOCKERCOMPOSE_SHA256=67c65c4015db38b526b262cee9d98915f8fcb56b42be7926a21a7ec2ec0c3d2c
RUN bash -eux -o pipefail <<'EOF'
    # Download docker-compose v2
    mkdir -p /usr/local/lib/docker/cli-plugins
    curl -fsSL --retry 25 --retry-all-errors "https://github.com/docker/compose/releases/download/v${DOCKERCOMPOSE_VERSION}/docker-compose-linux-riscv64" \
        -o "/usr/local/lib/docker/cli-plugins/docker-compose"

    # Verify package integrity
    echo "${DOCKERCOMPOSE_SHA256} /usr/local/lib/docker/cli-plugins/docker-compose" | sha256sum --check

    # Fix permissions on the file
    chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
EOF

# Download docker-buildx
FROM base-builder AS docker-buildx

ARG DOCKERBUILDX_VERSION=0.32.1
ARG DOCKERBUILDX_SHA256=ff29d3ad8756d11c2fdfddf068d794615d52a2b052b0e2e50edbdbeaf11cbe42
RUN bash -eux -o pipefail <<'EOF'
    # Download docker-buildx
    mkdir -p /usr/local/lib/docker/cli-plugins
    curl -fsSL --retry 25 --retry-all-errors "https://github.com/docker/buildx/releases/download/v${DOCKERBUILDX_VERSION}/buildx-v${DOCKERBUILDX_VERSION}.linux-riscv64" \
        -o "/usr/local/lib/docker/cli-plugins/docker-buildx"

    # Verify package integrity
    echo "${DOCKERBUILDX_SHA256} /usr/local/lib/docker/cli-plugins/docker-buildx" | sha256sum --check

    # Fix permissions on the file
    chmod +x /usr/local/lib/docker/cli-plugins/docker-buildx
EOF

# Build kubernetes
FROM go-1.26 AS kubernetes

WORKDIR /build

ARG KUBECTL_VERSION=1.35.3
RUN bash -eux -o pipefail <<'EOF'
    # Download kubernetes
    git clone --recurse-submodules --depth 1 https://github.com/kubernetes/kubernetes.git -b v${KUBECTL_VERSION}
    pushd kubernetes
    # Build & Install to /usr/local
    make WHAT="cmd/kubectl"
    install -m 755 -p _output/local/go/bin/kubectl /usr/local/bin/kubectl
    # Cleanup
    popd
    rm -rf kubernetes
EOF

# Build ninja
FROM base-builder AS ninja

WORKDIR /build

ARG NINJA_VERSION=1.13.2
RUN bash -eux -o pipefail <<'EOF'
    # Download ninja
    git clone --recurse-submodules --depth 1 https://github.com/ninja-build/ninja.git -b v${NINJA_VERSION}
    pushd ninja
    # Build & Install to /usr/local
    cmake -Bbuild -DBUILD_TESTING=OFF -DCMAKE_INSTALL_PREFIX=/usr/local
    cmake --build build --parallel
    cmake --install build
    # Cleanup
    popd
    rm -rf ninja
EOF

##########################################
# Build final image

ARG OS_VERSION
FROM docker.io/ubuntu:${OS_VERSION}

ENV DEBIAN_FRONTEND=noninteractive

RUN bash -eux -o pipefail <<'EOF'
    apt-get update
    apt-get install -y --no-install-recommends \
        sudo \
     && true

    rm -rf /var/lib/apt/lists/*

    # Add a user which will run the github actions
    useradd -m runner # also creates a `runner` group
    # Add runner to sudoers without password prompt
    echo "runner ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/runner
EOF

ENV RUNNER_TOOL_CACHE=/opt/hostedtoolcache
ENV RUNNER_OS=Linux
ENV RUNNER_ARCH=RISCV64

# Install Python
ARG PYTHON310_VERSION=3.10.20
COPY --from=python-3.10 --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON310_VERSION} ${RUNNER_TOOL_CACHE}/Python/${PYTHON310_VERSION}
ARG PYTHON311_VERSION=3.11.15
COPY --from=python-3.11 --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON311_VERSION} ${RUNNER_TOOL_CACHE}/Python/${PYTHON311_VERSION}
ARG PYTHON312_VERSION=3.12.13
COPY --from=python-3.12 --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON312_VERSION} ${RUNNER_TOOL_CACHE}/Python/${PYTHON312_VERSION}
ARG PYTHON313_VERSION=3.13.12
COPY --from=python-3.13 --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON313_VERSION} ${RUNNER_TOOL_CACHE}/Python/${PYTHON313_VERSION}
COPY --from=python-3.13t --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON313_VERSION}-freethreaded ${RUNNER_TOOL_CACHE}/Python/${PYTHON313_VERSION}-freethreaded
ARG PYTHON314_VERSION=3.14.3
COPY --from=python-3.14 --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON314_VERSION} ${RUNNER_TOOL_CACHE}/Python/${PYTHON314_VERSION}
COPY --from=python-3.14t --chown=runner:runner ${RUNNER_TOOL_CACHE}/Python/${PYTHON314_VERSION}-freethreaded ${RUNNER_TOOL_CACHE}/Python/${PYTHON314_VERSION}-freethreaded

# Install Go
ARG GO122_VERSION=1.22.12
COPY --from=go-1.22 --chown=runner:runner ${RUNNER_TOOL_CACHE}/go/${GO122_VERSION} ${RUNNER_TOOL_CACHE}/go/${GO122_VERSION}
ENV GOROOT_1_22_RISCV64=${RUNNER_TOOL_CACHE}/go/${GO122_VERSION}/riscv64
ARG GO123_VERSION=1.23.12
COPY --from=go-1.23 --chown=runner:runner ${RUNNER_TOOL_CACHE}/go/${GO123_VERSION} ${RUNNER_TOOL_CACHE}/go/${GO123_VERSION}
ENV GOROOT_1_23_RISCV64=${RUNNER_TOOL_CACHE}/go/${GO123_VERSION}/riscv64
ARG GO124_VERSION=1.24.13
COPY --from=go-1.24 --chown=runner:runner ${RUNNER_TOOL_CACHE}/go/${GO124_VERSION} ${RUNNER_TOOL_CACHE}/go/${GO124_VERSION}
ENV GOROOT_1_24_RISCV64=${RUNNER_TOOL_CACHE}/go/${GO124_VERSION}/riscv64
ARG GO125_VERSION=1.25.8
COPY --from=go-1.25 --chown=runner:runner ${RUNNER_TOOL_CACHE}/go/${GO125_VERSION} ${RUNNER_TOOL_CACHE}/go/${GO125_VERSION}
ENV GOROOT_1_25_RISCV64=${RUNNER_TOOL_CACHE}/go/${GO125_VERSION}/riscv64

RUN bash -eux -o pipefail <<'EOF'
    update-alternatives --install /usr/bin/go go ${RUNNER_TOOL_CACHE}/go/${GO124_VERSION}/riscv64/bin/go 100 \
        --slave /usr/bin/gofmt gofmt ${RUNNER_TOOL_CACHE}/go/${GO124_VERSION}/riscv64/bin/gofmt
EOF

# Install Node
ARG NODE20_VERSION=20.20.2
COPY --from=node-20 --chown=runner:runner ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION} ${RUNNER_TOOL_CACHE}/node/${NODE20_VERSION}
ARG NODE22_VERSION=22.22.2
COPY --from=node-22 --chown=runner:runner ${RUNNER_TOOL_CACHE}/node/${NODE22_VERSION} ${RUNNER_TOOL_CACHE}/node/${NODE22_VERSION}
ARG NODE24_VERSION=24.14.1
COPY --from=node-24 --chown=runner:runner ${RUNNER_TOOL_CACHE}/node/${NODE24_VERSION} ${RUNNER_TOOL_CACHE}/node/${NODE24_VERSION}

# Install Java environment variables
ENV JAVA_HOME_17_RISCV64=/usr/lib/jvm/temurin-17-jdk-riscv64/
ENV JAVA_HOME_21_RISCV64=/usr/lib/jvm/temurin-21-jdk-riscv64/
ENV JAVA_HOME_25_RISCV64=/usr/lib/jvm/temurin-25-jdk-riscv64/
ENV JAVA_HOME=${JAVA_HOME_17_RISCV64}

# Install Rust; it needs a runner user-writable location
COPY --from=rust --chown=runner:runner /build/rust/rustup /home/runner/.rustup
COPY --from=rust --chown=runner:runner /build/rust/cargo /home/runner/.cargo
ENV RUSTUP_HOME=/home/runner/.rustup
ENV CARGO_HOME=/home/runner/.cargo
ENV PATH=${RUSTUP_HOME}/bin:${CARGO_HOME}/bin:${PATH}

# Install Gradle
ARG GRADLE_VERSION=9.4.1
COPY --from=gradle /usr/share/gradle-${GRADLE_VERSION} /usr/share/gradle-${GRADLE_VERSION}
ENV GRADLE_HOME=/usr/share/gradle-${GRADLE_VERSION}
RUN bash -eux -o pipefail <<'EOF'
    update-alternatives --install /usr/bin/gradle gradle ${GRADLE_HOME}/bin/gradle 100
EOF

# Install Apache Maven
ARG MAVEN_VERSION=3.9.14
COPY --from=maven /usr/share/apache-maven-${MAVEN_VERSION} /usr/share/apache-maven-${MAVEN_VERSION}
ENV MAVEN_HOME=/usr/share/apache-maven-${MAVEN_VERSION}
RUN bash -eux -o pipefail <<'EOF'
    update-alternatives --install /usr/bin/mvn mvn ${MAVEN_HOME}/bin/mvn 100 \
        --slave /usr/bin/mvnDebug mvnDebug ${MAVEN_HOME}/bin/mvnDebug \
        --slave /usr/bin/mvnyjp mvnyjp ${MAVEN_HOME}/bin/mvnyjp
EOF

# Install ninja
COPY --from=ninja /usr/local/bin/ninja /usr/local/bin/ninja

# Install kubernetes
COPY --from=kubernetes /usr/local/bin/kubectl /usr/local/bin/kubectl

# Install Docker CLI Plugins
COPY --from=docker-compose /usr/local/lib/docker/cli-plugins/docker-compose /usr/local/lib/docker/cli-plugins/docker-compose
COPY --from=docker-buildx  /usr/local/lib/docker/cli-plugins/docker-buildx  /usr/local/lib/docker/cli-plugins/docker-buildx

# Setup PATH for local installs
ENV PATH=/home/runner/.local/bin:${PATH}

# Install all packages from Ubuntu registries
RUN bash -eux -o pipefail <<'EOF'
    # Get information about current OS
    source /etc/os-release

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        apt-transport-https \
        gpg \
     && true

    # Setup Temurin Repository
    curl -fsSL --retry 25 --retry-all-errors https://packages.adoptium.net/artifactory/api/gpg/key/public \
        | gpg --dearmor \
        | tee /etc/apt/trusted.gpg.d/adoptium.gpg >/dev/null
    echo "deb https://packages.adoptium.net/artifactory/deb ${VERSION_CODENAME} main" \
        | tee /etc/apt/sources.list.d/adoptium.list

    apt-get update
    apt-get install -y --no-install-recommends \
        acl \
        ant \
        ant-optional \
        apache2 \
        apt \
        apt-transport-https \
        aria2 \
        autoconf \
        automake \
        azure-vm-utils \
        base-files \
        bash \
        binutils \
        bison \
        brotli \
        bsdutils \
        build-essential \
        buildah \
        bzip2 \
        ca-certificates \
        ccache \
        chrony \
        cifs-utils \
        clang-{16,17,18} \
        clang-format-{16,17,18} \
        clang-tidy-{16,17,18} \
        cloud-init \
        cmake \
        coreutils \
        curl \
        dash \
        dbus \
        diffutils \
        dnsutils \
        docker-cli \
        docker-compose \
        dpkg \
        dpkg-dev \
        eatmydata \
        efibootmgr \
        fakeroot \
        file \
        findutils \
        flex \
        fonts-noto-color-emoji \
        ftp \
        g++ \
        g++-{12,13,14} \
        gettext-base \
        gcc \
        gcc-{12,13,14} \
        gettext-base \
        gfortran \
        gfortran-12 \
        gfortran-13 \
        gfortran-14 \
        gh \
        git \
        git-ftp \
        git-lfs \
        gnupg \
        gnupg2 \
        haveged \
        iproute2 \
        iputils-ping \
        jq \
        libatomic1 \
        libbz2-1.0 \
        libclang-{16,17,18}-dev \
        libexpat1 \
        libffi8 \
        libgdbm6 \
        libicu-dev \
        liblzma5 \
        libncursesw6 \
        libnss3-tools \
        libreadline8 \
        libsqlite3-0 \
        libsqlite3-dev \
        libssl-dev \
        libssl3 \
        libtool \
        libyaml-dev \
        locales \
        lz4 \
        m4 \
        make \
        mediainfo \
        mercurial \
        net-tools \
        netcat-openbsd \
        openssh-client \
        p7zip-full \
        parallel \
        patchelf \
        php8.3-pgsql \
        php8.3-phpdbg \
        php8.3-pspell \
        php8.3-readline \
        php8.3-redis \
        php8.3-snmp \
        php8.3-soap \
        php8.3-sqlite3 \
        php8.3-sybase \
        php8.3-tidy \
        php8.3-xdebug \
        php8.3-xml \
        php8.3-xsl \
        php8.3-yaml \
        php8.3-zip \
        php8.3-zmq \
        pigz \
        pkg-config \
        podman \
        pollinate \
        postgresql-16 \
        python-babel-localedata \
        python-is-python3 \
        python3 \
        python3-babel \
        python3-dev \
        python3-jinja2 \
        python3-json-pointer \
        python3-jsonpatch \
        python3-jsonschema \
        python3-markupsafe \
        python3-parted \
        python3-pip \
        python3-pyrsistent \
        python3-serial \
        python3-six \
        python3-tz \
        python3-venv \
        rpm \
        rsync \
        ruby-full \
        shellcheck \
        skopeo \
        snmp \
        software-properties-common \
        sphinxsearch \
        sqlite3 \
        ssh \
        ssh-import-id \
        sshpass \
        sudo \
        swig \
        sysstat \
        systemd-coredump \
        tar \
        telnet \
        temurin-17-jdk \
        temurin-21-jdk \
        temurin-25-jdk \
        texinfo \
        time \
        tk \
        tree \
        tzdata \
        ubuntu-minimal \
        ubuntu-server \
        ubuntu-standard \
        unzip \
        upx \
        upx-ucl \
        util-linux \
        uuid-runtime \
        wget \
        xvfb \
        xz-utils \
        zip \
        zlib1g \
        zlib1g-dev \
        zsync \
     && true

    if [[ "${VERSION_ID}" == "24.04" ]]; then
        # Install 24.04 specific packages
        apt-get install -y --no-install-recommends \
            p7zip-rar \
         && true
    elif [[ "${VERSION_ID}" == "26.04" ]]; then
        # Install 26.04 specific packages
        true # nothing yet
    else
        echo "Unknown Ubuntu version ${VERSION_ID}"
        exit 1
    fi

    # Clean up apt cache to reduce image size
    rm -rf /var/lib/apt/lists/*
EOF

# Setup runner user
WORKDIR /home/runner
USER runner

# Setup GitHub runner
ARG RUNNER_VERSION=2.333.1
ARG RUNNER_SHA256=b7fe06dae879678b817dbd4286d3527ba3a8867641ea932a0609fb1eed392b7b # https://github.com/Cloud-V-10xE/github-runner-riscv/releases/tag/${RUNNER_VERSION}-riscv64-net8
RUN bash -eux -o pipefail <<'EOF'
    curl -fsSL --retry 25 --retry-all-errors https://github.com/Cloud-V-10xE/github-runner-riscv/releases/download/v${RUNNER_VERSION}-riscv64-net8/actions-runner-linux-riscv64-${RUNNER_VERSION}.tar.gz \
        -o actions-runner-linux-riscv64-${RUNNER_VERSION}.tar.gz

    # Verify package integrity
    echo "${RUNNER_SHA256} actions-runner-linux-riscv64-${RUNNER_VERSION}.tar.gz" | sha256sum --check

    # Unpack tar file
    mkdir -p /home/runner/actions-runner/cached/${RUNNER_VERSION}
    tar -xzf actions-runner-linux-riscv64-${RUNNER_VERSION}.tar.gz -C /home/runner/actions-runner/cached/${RUNNER_VERSION}
    rm actions-runner-linux-riscv64-${RUNNER_VERSION}.tar.gz

    # Install dependencies for the runner (if any)
    sudo /home/runner/actions-runner/cached/${RUNNER_VERSION}/bin/installdependencies.sh
EOF

ENV RUNNER_VERSION=${RUNNER_VERSION}

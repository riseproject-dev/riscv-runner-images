    mkdir -p /opt/maven
    tar -xzf apache-maven-${MAVEN_VERSION}-bin.tar.gz -C /opt/maven --strip-components=1

    # Remove now-unnecessary tarball
    rm apache-maven-${MAVEN_VERSION}-bin.tar.gz
EOF

# Download Node.js 20
FROM base-builder AS node-20

ARG NODE20_VERSION=20.20.2
ARG NODE20_SHA256=97a1b381eb457a904973cd3fa7999feb4fded5d286f4da08bbd0bf112601b0f4 # https://unofficial-builds.nodejs.org/download/release/v20.20.2/SHASUMS256.txt
RUN bash -eux -o pipefail <<'EOF'
    # Download Node.js 20 binary tarball (unofficial riscv64 build)
    wget --progress=dot:giga "https://unofficial-builds.nodejs.org/download/release/v${NODE20_VERSION}/node-v${NODE20_VERSION}-linux-riscv64.tar.xz" \
        -O "node-v${NODE20_VERSION}.tar.xz"

    # Verify package integrity
    echo "${NODE20_SHA256}  node-v${NODE20_VERSION}.tar.xz" | sha256sum --check

    # Unpack to /opt/node-20
    mkdir -p /opt/node-20
    tar -xJf "node-v${NODE20_VERSION}.tar.xz" -C /opt/node-20 --strip-components 1

    # Remove now-unnecessary tarball
    rm "node-v${NODE20_VERSION}.tar.xz"

    # Smoke test
    /opt/node-20/bin/node --version
EOF


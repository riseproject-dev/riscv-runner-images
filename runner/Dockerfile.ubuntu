RUN bash -eux -o pipefail <<'EOF'
    # Download Node.js 24 binary tarball (unofficial riscv64 build)
    wget --progress=dot:giga "https://unofficial-builds.nodejs.org/download/release/v${NODE24_VERSION}/node-v${NODE24_VERSION}-linux-riscv64.tar.xz" \
        -O "node-v${NODE24_VERSION}.tar.xz"

    # Verify package integrity
    echo "${NODE24_SHA256}  node-v${NODE24_VERSION}.tar.xz" | sha256sum --check

    # Unpack to /opt/node-24
    mkdir -p /opt/node-24
    tar -xJf "node-v${NODE24_VERSION}.tar.xz" -C /opt/node-24 --strip-components 1

    # Remove now-unnecessary tarball
    rm "node-v${NODE24_VERSION}.tar.xz"

    # Smoke test
    /opt/node-24/bin/node --version
EOF

# Download Rust 1.94.0
FROM base-builder AS rust

ARG RUSTUP_VERSION=1.29.0
ARG RUSTTOOLCHAIN_VERSION=1.94.1
ENV RUSTUP_HOME=/opt/rust/rustup
ENV CARGO_HOME=/opt/rust/cargo
RUN bash -eux -o pipefail <<'EOF'
    wget --progress=dot:giga -O - https://sh.rustup.rs | sh -s -- \
        -y \
        --default-toolchain ${RUSTTOOLCHAIN_VERSION} \
        --component rustfmt
EOF

# Build sccache 0.14.0 (with gha caching support)
FROM rust AS sccache

ARG SCCACHE_VERSION=0.14.0
RUN bash -eux -o pipefail <<'EOF'
    export PATH="${CARGO_HOME}/bin:${PATH}"
    cargo install --no-default-features --features=gha,s3 sccache@${SCCACHE_VERSION}
EOF

# Dockerload docker-compose v2 2.38.2
FROM base-builder AS docker-compose

ARG DOCKERCOMPOSE_VERSION=2.38.2
ARG DOCKERCOMPOSE_SHA256=67c65c4015db38b526b262cee9d98915f8fcb56b42be7926a21a7ec2ec0c3d2c
RUN bash -eux -o pipefail <<'EOF'
    # Download docker-compose v2 2.38.2
    mkdir -p /usr/local/lib/docker/cli-plugins
    wget --progress=dot:giga "https://github.com/docker/compose/releases/download/v${DOCKERCOMPOSE_VERSION}/docker-compose-linux-riscv64" \
        -O "/usr/local/lib/docker/cli-plugins/docker-compose"

    # Verify package integrity
    echo "${DOCKERCOMPOSE_SHA256} /usr/local/lib/docker/cli-plugins/docker-compose" | sha256sum --check

    # Fix permissions on the file
    chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
EOF

# Download docker-buildx 0.32.1
FROM base-builder AS docker-buildx

ARG DOCKERBUILDX_VERSION=0.33.0
ARG DOCKERBUILDX_SHA256=5003b19409f2dfb38fc5f00a8eac4b1d810f6087b88ae007c6983287b93095dd # https://api.github.com/repos/docker/buildx/releases/tags/v0.33.0
RUN bash -eux -o pipefail <<'EOF'
    # Download docker-buildx 0.32.1
    mkdir -p /usr/local/lib/docker/cli-plugins
    wget --progress=dot:giga "https://github.com/docker/buildx/releases/download/v${DOCKERBUILDX_VERSION}/buildx-v${DOCKERBUILDX_VERSION}.linux-riscv64" \
        -O "/usr/local/lib/docker/cli-plugins/docker-buildx"

    # Verify package integrity
    echo "${DOCKERBUILDX_SHA256} /usr/local/lib/docker/cli-plugins/docker-buildx" | sha256sum --check

    # Fix permissions on the file
    chmod +x /usr/local/lib/docker/cli-plugins/docker-buildx
EOF

# Build GitHub CLI v2.87.3
FROM go-1.26 AS gh

ARG GH_VERSION=2.89.0
RUN bash -eux -o pipefail <<'EOF'
    # Download GitHub CLI v2.87.3
    git clone --recurse-submodules --depth 1 https://github.com/cli/cli.git -b v${GH_VERSION}
    pushd cli

    # Make sure Go 1.26 is on the PATH
    export PATH=/opt/go-1.26/bin:${PATH}
    go version

    # Install to /opt/gh
    make install prefix=/opt/gh

    # Smoke test
    /opt/gh/bin/gh version
EOF

# Build kubernetes 1.35.2
FROM go-1.26 AS kubernetes

ARG KUBECTL_VERSION=1.35.3
RUN bash -eux -o pipefail <<'EOF'
    # Download kubernetes v1.35.2
    git clone --recurse-submodules --depth 1 https://github.com/kubernetes/kubernetes.git -b v${KUBECTL_VERSION}
    pushd kubernetes

    # Make sure Go 1.26 is on the PATH
    export PATH=/opt/go-1.26/bin:${PATH}
    go version

    # Install to /opt/kubernetes
    make WHAT="cmd/kubectl"
    mkdir -p /opt/kubernetes/bin
    cp _output/local/go/bin/* /opt/kubernetes/bin/

    # Smoke test
    /opt/kubernetes/bin/kubectl version --client
EOF

# Build ninja 1.13.2
FROM base-builder AS ninja

ARG NINJA_VERSION=1.13.2
RUN bash -eux -o pipefail <<'EOF'
    # Download ninja v1.13.2
    git clone --recurse-submodules --depth 1 https://github.com/ninja-build/ninja.git -b v${NINJA_VERSION}
    pushd ninja

    # Install to /opt/ninja
    cmake -Bbuild -DBUILD_TESTING=OFF -DCMAKE_INSTALL_PREFIX=/opt/ninja
    cmake --build build
    cmake --install build

    # Smoke test
    /opt/ninja/bin/ninja --version
EOF

# Build final image

ARG OS_VERSION=latest
FROM docker.io/ubuntu:${OS_VERSION}

ENV DEBIAN_FRONTEND=noninteractive
RUN bash -eux -o pipefail <<'EOF'
    # Get information about current OS
    source /etc/os-release

    apt-get update -qq
    apt-get install -qq -y --no-install-recommends \
        acl \
        aria2 \
        autoconf \
        automake \
        binutils \
        bison \
        brotli \
        build-essential \
        bzip2 \
        ca-certificates \
        ccache \
        clang-{16,17,18} \
        clang-tidy-{16,17,18} \
        clang-format-{16,17,18} \
        cmake \
        coreutils \
        curl \
        dbus \
        dnsutils \
        docker-cli \
        docker-compose \
        dpkg \
        dpkg-dev \
        fakeroot \
        file \
        findutils \
        flex \
        fonts-noto-color-emoji \
        ftp \
        g++ \
        g++-14 \
        gettext-base \
        gcc \
        gcc-14 \
        git \
        git-lfs \
        gnupg2 \
        haveged \
        iproute2 \
        iputils-ping \
        jq \
        libatomic1 \
        libclang-{16,17,18}-dev \
        libbz2-1.0 \
        libexpat1 \
        libffi8 \
        libgdbm6 \
        libicu-dev \
        liblzma5 \
        libncursesw6 \
        libnss3-tools \
        libreadline8 \
        libsqlite3-0 \
        libsqlite3-dev \
        libssl-dev \
        libssl3 \
        libtool \
        libyaml-dev \
        locales \
        lz4 \
        m4 \
        make \
        mediainfo \
        mercurial \
        net-tools \
        netcat-openbsd \
        openssh-client \
        p7zip-full \
        parallel \
        patchelf \
        pigz \
        pkg-config \
        pollinate \
        python-is-python3 \
        rpm \
        rsync \
        shellcheck \
        sphinxsearch \
        sqlite3 \
        ssh \
        sshpass \
        sudo \
        swig \
        systemd-coredump \
        tar \
        telnet \
        texinfo \
        time \
        tk \
        tree \
        tzdata \
        unzip \
        upx \
        uuid-runtime \
        wget \
        xvfb \
        xz-utils \
        zip \
        zlib1g \
        zsync \
     && true

    if [[ "${VERSION_ID}" == "24.04" ]]; then
        # Install 24.04 specific packages
        apt-get install -qq -y --no-install-recommends \
            p7zip-rar \
         && true
    elif [[ "${VERSION_ID}" == "26.04" ]]; then
        # Install 26.04 specific packages
        true # nothing yet
    else
        echo "Unknown Ubuntu version ${VERSION_ID}"
        exit 1
    fi

    # Clean up apt cache to reduce image size
    rm -rf /var/lib/apt/lists/*

    # Add a user which will run the github actions
    useradd -m runner # also creates a `runner` group
    # Add runner to sudoers without password prompt
    echo "runner ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/runner
EOF

# Install Python 3.10-3.14

COPY --from=python-3.10 /opt/python-3.10 /opt/python-3.10
COPY --from=python-3.11 /opt/python-3.11 /opt/python-3.11
COPY --from=python-3.12 /opt/python-3.12 /opt/python-3.12
COPY --from=python-3.13 /opt/python-3.13 /opt/python-3.13
COPY --from=python-3.13t /opt/python-3.13t /opt/python-3.13t
COPY --from=python-3.14 /opt/python-3.14 /opt/python-3.14
COPY --from=python-3.14t /opt/python-3.14t /opt/python-3.14t

# FIXME: figure out whether/how to have the free-threaded versions on the PATH
ENV PATH=/opt/python-3.10/bin:/opt/python-3.11/bin:/opt/python-3.12/bin:/opt/python-3.13/bin:/opt/python-3.14/bin:${PATH}
# Set python-3.12 as the default version
ENV pythonLocation=/opt/python-3.12
ENV Python_ROOT_DIR=${pythonLocation}
ENV Python2_ROOT_DIR=${pythonLocation}
ENV Python3_ROOT_DIR=${pythonLocation}
ENV PATH=${pythonLocation}/bin:${PATH}

# Install Go 1.22-1.25
COPY --from=go-1.22 /opt/go-1.22 /opt/go-1.22
COPY --from=go-1.23 /opt/go-1.23 /opt/go-1.23
COPY --from=go-1.24 /opt/go-1.24 /opt/go-1.24
COPY --from=go-1.25 /opt/go-1.25 /opt/go-1.25
RUN bash -eux -o pipefail <<'EOF'
    # Make Go 1.24 the default go binary
    # Set up update-alternatives for go and gofmt
    update-alternatives --install /usr/bin/go go /opt/go-1.22/bin/go 22 \
        --slave /usr/bin/gofmt gofmt /opt/go-1.22/bin/gofmt
    update-alternatives --install /usr/bin/go go /opt/go-1.23/bin/go 23 \
        --slave /usr/bin/gofmt gofmt /opt/go-1.23/bin/gofmt
    update-alternatives --install /usr/bin/go go /opt/go-1.24/bin/go 100 \
        --slave /usr/bin/gofmt gofmt /opt/go-1.24/bin/gofmt
    update-alternatives --install /usr/bin/go go /opt/go-1.25/bin/go 25 \
        --slave /usr/bin/gofmt gofmt /opt/go-1.25/bin/gofmt
EOF

# Install Java 17, 21, 25
COPY --from=java-17 /opt/jdk-17 /opt/jdk-17
COPY --from=java-21 /opt/jdk-21 /opt/jdk-21
COPY --from=java-25 /opt/jdk-25 /opt/jdk-25
ENV JAVA_HOME_17_RISCV64=/opt/jdk-17
ENV JAVA_HOME_21_RISCV64=/opt/jdk-21
ENV JAVA_HOME_25_RISCV64=/opt/jdk-25
ENV JAVA_HOME=/opt/jdk-25
ENV PATH=${JAVA_HOME}/bin:${PATH}

# Install Apache Ant
COPY --from=ant /opt/ant /opt/ant
ENV ANT_HOME=/opt/ant
ENV PATH=${ANT_HOME}/bin:${PATH}

# Install Gradle
COPY --from=gradle /opt/gradle /opt/gradle
ENV GRADLE_HOME=/opt/gradle
ENV PATH=${GRADLE_HOME}/bin:${PATH}

# Install Apache Maven
COPY --from=maven /opt/maven /opt/maven
ENV MAVEN_HOME=/opt/maven
ENV PATH=${MAVEN_HOME}/bin:${PATH}

# Install Node 20, 22, 24
COPY --from=node-20 /opt/node-20 /opt/node-20
COPY --from=node-22 /opt/node-22 /opt/node-22
COPY --from=node-24 /opt/node-24 /opt/node-24
RUN bash -eux -o pipefail <<'EOF'
    # Make Node 20 the default version
    update-alternatives --install /usr/bin/node node /opt/node-20/bin/node 100 \
        --slave /usr/bin/npm npm /opt/node-20/bin/npm \
        --slave /usr/bin/npx npx /opt/node-20/bin/npx \
        --slave /usr/bin/corepack corepack /opt/node-20/bin/corepack
    update-alternatives --install /usr/bin/node node /opt/node-22/bin/node 22 \
        --slave /usr/bin/npm npm /opt/node-22/bin/npm \
        --slave /usr/bin/npx npx /opt/node-22/bin/npx \
        --slave /usr/bin/corepack corepack /opt/node-22/bin/corepack
    update-alternatives --install /usr/bin/node node /opt/node-24/bin/node 24 \
        --slave /usr/bin/npm npm /opt/node-24/bin/npm \
        --slave /usr/bin/npx npx /opt/node-24/bin/npx \
        --slave /usr/bin/corepack corepack /opt/node-24/bin/corepack
EOF

# Install Docker CLI Plugins
COPY --from=docker-compose /usr/local/lib/docker/cli-plugins/docker-compose /usr/local/lib/docker/cli-plugins/docker-compose
COPY --from=docker-buildx  /usr/local/lib/docker/cli-plugins/docker-buildx  /usr/local/lib/docker/cli-plugins/docker-buildx

# Install GitHub CLI
COPY --from=gh /opt/gh /opt/gh
ENV PATH=/opt/gh/bin:${PATH}

# Install Kubernetes
COPY --from=kubernetes /opt/kubernetes /opt/kubernetes
ENV PATH=/opt/kubernetes/bin:${PATH}

# Install ninja
COPY --from=ninja /opt/ninja /opt/ninja
ENV PATH=/opt/ninja/bin:${PATH}

# Install Rust; it needs a runner user-writable location
COPY --from=rust --chown=runner:runner /opt/rust/rustup /home/runner/.rustup
COPY --from=rust --chown=runner:runner /opt/rust/cargo /home/runner/.cargo
ENV RUSTUP_HOME=/home/runner/.rustup
ENV CARGO_HOME=/home/runner/.cargo
ENV PATH=${RUSTUP_HOME}/bin:${CARGO_HOME}/bin:${PATH}

# Install sccache
COPY --from=sccache --chown=runner:runner /opt/rust/cargo/bin/sccache ${CARGO_HOME}/bin/sccache

# Setup PATH for local installs
ENV PATH=/home/runner/.local/bin:${PATH}

# Setup runner user
WORKDIR /home/runner
USER runner

# Setup GitHub runner
ARG RUNNER_VERSION=2.331.0
RUN bash -eux -o pipefail <<'EOF'
    curl -fsSL https://github.com/alitariq4589/github-runner-riscv/releases/download/v${RUNNER_VERSION}-riscv64-net8/actions-runner-linux-riscv64-${RUNNER_VERSION}.tar.gz \
        | tar xzf -
    # Install dependencies for the runner (if any)
    sudo ./bin/installdependencies.sh
EOF
